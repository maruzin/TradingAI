# =============================================================================
# TradingAI — Environment configuration
# Copy to `.env` and fill in. NEVER commit `.env` (it's in .gitignore).
# =============================================================================

# --- General ---
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO

# CORS origins for the FastAPI backend. JSON list. Local dev defaults to
# ["http://localhost:3000","http://127.0.0.1:3000"] — production MUST set
# this to your Vercel URL(s), otherwise browser requests will be blocked.
# Example: CORS_ORIGINS=["https://trading-ai.vercel.app"]
CORS_ORIGINS=

# Auth dev-mode shortcut. When true AND SUPABASE_URL is empty AND environment
# is not production, the literal token "dev" maps to a fake admin user.
# Production always rejects, regardless of this flag. Default false.
ALLOW_DEV_AUTH=false

# --- LLM provider ---
# Phase 1: anthropic | openai
# Phase 2: ollama | mlx | routed (router that prefers local, falls back to cloud)
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Phase 2 (Mac via Tailscale)
OLLAMA_BASE_URL=http://your-mac.tail-XXXXX.ts.net:11434
OLLAMA_MODEL=qwen2.5:32b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=bge-large

# Routed provider config (only when LLM_PROVIDER=routed)
ROUTED_REASONING=ollama
ROUTED_EMBEDDING=ollama
ROUTED_FALLBACK=anthropic

# --- Database (Supabase) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # backend-only, never to frontend
SUPABASE_DB_URL=postgres://postgres:postgres@localhost:5432/tradingai

# --- Cache / queue ---
REDIS_URL=redis://localhost:6379/0

# --- Market data ---
COINGECKO_API_KEY=                 # optional, free tier works without
CRYPTOPANIC_API_KEY=
LUNARCRUSH_API_KEY=
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
BSCSCAN_API_KEY=
SOLSCAN_API_KEY=
GLASSNODE_API_KEY=                 # free tier OK
DUNE_API_KEY=

# --- Macro & cross-asset (Dimension 5 inputs) ---
FRED_API_KEY=                      # https://fred.stlouisfed.org/ — free, official US macro
ALPHA_VANTAGE_API_KEY=             # optional, equities / forex backup
GDELT_API_KEY=                     # GDELT 2.0 DOC API is keyless; this slot reserved for paid tiers
COINGLASS_API_KEY=                 # https://www.coinglass.com — funding rates + open interest

# --- Exchanges (read-only keys, stored encrypted per-user in prod; this is dev only) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
POSTMARK_API_KEY=                  # for transactional email
EMAIL_FROM=tradingai@yourdomain.tld

# --- Frontend (NEXT_PUBLIC_ prefix exposes to browser; keep secrets out) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Observability ---
SENTRY_DSN=

# --- Fly.io deploy ---
# Used by the `fly` CLI (locally) and by GitHub Actions auto-deploy. Mint via
# `fly tokens create deploy` in the Fly dashboard. Add the same value as a
# GitHub Actions repo secret named FLY_API_TOKEN if you want CI to deploy.
FLY_API_TOKEN=
